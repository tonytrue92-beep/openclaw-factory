#!/usr/bin/env bash
# Git pre-commit hook — блокирует коммит если в staged-файлах есть
# потенциальные секреты (API-ключи, Telegram-токены, Bearer-токены).
#
# Активируется через: bash scripts/install-git-hooks.sh
#
# Как работает:
#   1. Вытягивает список staged-файлов (только то что коммитится)
#   2. Для каждого текстового файла делает grep на паттерны секретов
#   3. Если staged-файлы затронули scripts/ или .github/ —
#      дополнительно запускает полный security-audit.sh
#   4. При любом найденном секрете — отклоняет коммит с объяснением
#
# Обход (в крайнем случае): git commit --no-verify

set -euo pipefail

RED=$'\033[0;31m'
YELLOW=$'\033[1;33m'
GREEN=$'\033[0;32m'
DIM=$'\033[2m'
NC=$'\033[0m'

staged_files=$(git diff --cached --name-only --diff-filter=ACM)
if [[ -z "$staged_files" ]]; then
  exit 0
fi

echo "${DIM}━━━ pre-commit security scan ━━━${NC}"

found=0
violation_lines=""

add_violation() {
  found=$((found + 1))
  violation_lines+="  • $1"$'\n'
}

for f in $staged_files; do
  # Пропускаем .githooks — hook сам себя не проверяет
  [[ "$f" == .githooks/* ]] && continue

  # Пропускаем бинарные файлы
  git show ":$f" 2>/dev/null | grep -Iq . 2>/dev/null || continue

  content=$(git show ":$f" 2>/dev/null || true)
  [[ -z "$content" ]] && continue

  # sk-* API ключи (OpenAI/Anthropic/opencode.ai формат) — длинные
  # False-positives фильтруем: example, REDACTED, proj-abc, test, xxx, точки-заглушки
  leak=$(echo "$content" \
    | grep -nE 'sk-[A-Za-z0-9_-]{25,}' \
    | grep -vE '(example|REDACTED|proj-abc|test|sk-xxx|sk-\.\.|"sk-•)' \
    || true)
  if [[ -n "$leak" ]]; then
    add_violation "$f — sk-* API key (первая строка: $(echo "$leak" | head -1))"
  fi

  # Telegram bot tokens — формат цифры:буквы_цифры_тире
  leak=$(echo "$content" \
    | grep -nE '[0-9]{9,12}:AA[A-Za-z0-9_-]{30,}' \
    | grep -vE '(7123456789|REDACTED|example|demo_|1234567890)' \
    || true)
  if [[ -n "$leak" ]]; then
    add_violation "$f — Telegram bot token (первая строка: $(echo "$leak" | head -1))"
  fi

  # Bearer-токены / Authorization headers
  leak=$(echo "$content" \
    | grep -nE '(Bearer[[:space:]]+|Authorization:[[:space:]]*Bearer[[:space:]]+)[A-Za-z0-9._-]{30,}' \
    | grep -vE '(REDACTED|example|xxx|test)' \
    || true)
  if [[ -n "$leak" ]]; then
    add_violation "$f — Bearer token"
  fi
done

# Если задеты критичные директории — прогоняем полный security-audit.
# security-audit.sh лежит в разных местах в зависимости от репо.
relevant=$(echo "$staged_files" | grep -E '^(scripts/|templates/|\.github/)' || true)
if [[ -n "$relevant" ]]; then
  AUDIT=""
  [[ -x .github/workflows/security-audit.sh ]] && AUDIT=".github/workflows/security-audit.sh"
  [[ -z "$AUDIT" && -x scripts/security-audit.sh ]] && AUDIT="scripts/security-audit.sh"

  if [[ -n "$AUDIT" ]]; then
    tmp=$(mktemp)
    if ! bash "$AUDIT" >"$tmp" 2>&1; then
      add_violation "security-audit.sh ($AUDIT) упал"
      echo "${YELLOW}Последние строки лога security-audit:${NC}"
      tail -15 "$tmp"
    fi
    rm -f "$tmp"
  fi
fi

if [[ $found -gt 0 ]]; then
  echo ""
  echo "${RED}✗ Коммит отклонён — обнаружено проблем: ${found}${NC}"
  echo ""
  echo -n "$violation_lines"
  echo ""
  echo "${YELLOW}Что делать:${NC}"
  echo "  1. Реальный секрет → удалить / заменить на [REDACTED]"
  echo "  2. Ложное срабатывание → добавить 'example' / 'REDACTED' к тестовому значению"
  echo "  3. Обойти hook (ТОЛЬКО осознанно): ${DIM}git commit --no-verify${NC}"
  echo ""
  exit 1
fi

echo "${GREEN}✓ Секретов не найдено${NC}"
exit 0
